{{- $books := .Site.Data.bibliotheque.books -}}
{{- $categories := .Site.Data.metadata.books.categories -}}
{{- $seeBook := i18n "bibli_see_book" -}}
{
  "revision": {{ .Site.Data.bibliotheque.revision | jsonify }},
  "categories": {
    {{- $first := true -}}
    {{- range $categories -}}
    {{- if not $first }},{{ end -}}
    {{- $first = false }}
    {{- $i18nKey := printf "bibli_cat_%s" . }}
    {{ . | jsonify }}: {
      "label": {{ i18n $i18nKey | jsonify }}
    }
    {{- end }}
  },
  "seeBookLabel": {{ $seeBook | jsonify }},
  "languages": [
    {{- $langs := slice -}}
    {{- range $books -}}
      {{- with .inLanguage -}}
        {{- if not (in $langs .) -}}
          {{- $langs = $langs | append . -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
    {{- range $i, $l := sort $langs -}}
    {{- if $i }},{{ end }}{{ $l | jsonify }}
    {{- end }}
  ],
  "books": [
    {{- range $i, $book := $books }}
    {{- if $i }},{{ end }}
    {
      "author": {{ $book.author | jsonify }},
      "name": {{ $book.name | jsonify }},
      "publisher": {{ $book.publisher | default "" | jsonify }},
      "datePublished": {{ $book.datePublished | default "" | jsonify }},
      "numberOfPages": {{ $book.numberOfPages | default 0 }},
      "bookFormat": {{ $book.bookFormat | default "" | jsonify }},
      "isbn": {{ $book.isbn | default "" | jsonify }},
      "image": {{ $book.image | default "" | jsonify }},
      "inLanguage": {{ $book.inLanguage | default "" | jsonify }},
      "genre": {{ $book.genre | jsonify }}
    }
    {{- end }}
  ]
}
