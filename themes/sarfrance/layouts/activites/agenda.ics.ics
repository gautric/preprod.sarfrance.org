{{- $year := .Params.year | default "2026" -}}
{{- $events := where .Site.Data.agenda.events "date" "ge" (printf "%s-01-01" $year) -}}
{{- $events = where $events "date" "le" (printf "%s-12-31" $year) -}}
BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//SAR France//Agenda//FR
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:SAR France – Agenda {{ $year }}
X-WR-TIMEZONE:Europe/Paris
{{ range $events -}}
{{- $intervalParts := split .date "/" -}}
{{- $startRaw := index $intervalParts 0 -}}
{{- $hasEnd := gt (len $intervalParts) 1 -}}
{{- $startDateOnly := index (split $startRaw "T") 0 -}}
{{- $startClean := replace $startDateOnly "-" "" -}}
{{- $titleLower := .title | lower | replaceRE "[^a-z0-9]+" "-" | replaceRE "^-+|-+$" "" -}}
{{- $uid := printf "%s-%s@sarfrance.org" $startClean $titleLower -}}
BEGIN:VEVENT
UID:{{ $uid }}
{{- if strings.Contains $startRaw "T" -}}
{{- $dtParts := split $startRaw "T" -}}
{{- $datePart := replace (index $dtParts 0) "-" "" -}}
{{- $timePart := replace (index $dtParts 1) ":" "" }}
DTSTART;TZID=Europe/Paris:{{ $datePart }}T{{ $timePart }}
{{- else }}
DTSTART;VALUE=DATE:{{ $startClean }}
{{- end }}
{{- if $hasEnd -}}
{{- $endRaw := index $intervalParts 1 -}}
{{- $endTime := time.AsTime (printf "%sT00:00:00Z" $endRaw) -}}
{{- $endPlusOne := $endTime.AddDate 0 0 1 }}
DTEND;VALUE=DATE:{{ $endPlusOne.Format "20060102" }}
{{- end }}
SUMMARY:{{ .title }}
{{- if and .description (ne .description "") }}
DESCRIPTION:{{ .description }}
{{- else }}
DESCRIPTION:{{ .title }} – SAR France
{{- end }}
{{- with .location }}
LOCATION:{{ . }}
{{- end }}
END:VEVENT
{{ end -}}
END:VCALENDAR
